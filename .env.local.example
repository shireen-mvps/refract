# Get your Anthropic API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# (Optional) Image generation — get your Gemini API key at https://aistudio.google.com/apikey
# Free tier available. Uses Gemini 2.5 Flash (multimodal — supports product photo uploads).
# Leave blank or remove this line to disable image generation.
GEMINI_API_KEY=your_gemini_key_here

# (Optional) Rate limiting — get free credentials at https://upstash.com
# Create a Redis database and copy the REST URL and token below.
# Leave blank to disable rate limiting (recommended for local dev).
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
