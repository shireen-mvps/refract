# Get your Anthropic API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# (Optional) Image generation — get your Gemini API key at https://aistudio.google.com/apikey
# Free tier available. Uses Gemini 2.0 Flash (multimodal — supports product photo uploads).
# Leave blank or remove this line to disable image generation.
GEMINI_API_KEY=your_gemini_key_here
